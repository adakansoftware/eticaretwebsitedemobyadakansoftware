{
  "name": "adakan-commerce-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types tests/run-tests.mts",
    "test:integration": "node --experimental-strip-types tests/integration-outbox.mts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:prepare": "npm run prisma:seed",
    "ops:preflight": "node --experimental-strip-types scripts/preflight.mts",
    "ops:audit:summary": "node --experimental-strip-types scripts/audit-summary.mts",
    "ops:status": "node --experimental-strip-types scripts/ops-status.mts",
    "ops:assert": "node --experimental-strip-types scripts/ops-assert.mts",
    "ops:report": "node --experimental-strip-types scripts/ops-report.mts",
    "ops:outbox": "node --import tsx scripts/process-outbox.mts",
    "ops:outbox:requeue:dry": "node --experimental-strip-types scripts/outbox-requeue.mts",
    "ops:outbox:requeue:apply": "node --experimental-strip-types scripts/outbox-requeue.mts --apply",
    "ops:orders:anomalies": "node --experimental-strip-types scripts/order-anomalies.mts",
    "ops:orders:timeout:dry": "node --experimental-strip-types scripts/order-timeouts.mts",
    "ops:orders:timeout:apply": "node --experimental-strip-types scripts/order-timeouts.mts --apply",
    "ops:backup:drill": "node --experimental-strip-types scripts/backup-drill.mts",
    "ops:backup:assert": "node --experimental-strip-types scripts/backup-drill.mts --assert-ready",
    "ops:cleanup:dry": "node --experimental-strip-types scripts/ops-cleanup.mts --dry-run",
    "ops:cleanup:apply": "node --experimental-strip-types scripts/ops-cleanup.mts --apply",
    "verify": "npm run ops:preflight && npm run lint && npm run typecheck && npm run test && npm run test:integration && npm run build",
    "check": "npm run verify",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.56.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.1.0",
    "lucide-react": "^0.554.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.6",
    "prisma": "^6.16.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
